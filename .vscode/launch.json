{
  "version": "0.2.0",
  "configurations": [

    {
      "name": "autoc: Core Dump Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/autoc",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "coreDumpPath": "${input:coreDumpPath}",
      "miDebuggerPath": "/usr/bin/gdb"
    },
    {
      "name": "minisim: Core Dump Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/minisim",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "coreDumpPath": "${input:coreDumpPath}",
      "miDebuggerPath": "/usr/bin/gdb"
    },
    {
      "name": "crrcsim: Core Dump Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/crrcsim/crrcsim",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "coreDumpPath": "${input:coreDumpPath}",
      "miDebuggerPath": "/usr/bin/gdb"
    },
    {
      "name": "(gdb) Attach Minisim",
      "type": "cppdbg",
      "request": "attach",
      "program": "${workspaceFolder}/build/minisim",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "(gdb) Attach CRRCSim",
      "type": "cppdbg",
      "request": "attach",
      "program": "${workspaceFolder}/build/crrcsim/crrcsim",
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "(gdb) autoc Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/autoc",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "make",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "(gdb) renderer Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/renderer",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "make",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "(gdb) minisim Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/minisim",
      "args": [
        "111",
        "37",
        "1234"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "(gdb) crrcsim Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/crrcsim/crrcsim",
      "args": [
        "-g",
        "autoc_config.xml",
        "-p",
        "1234",
        "-i",
        "AUTOC"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/crrcsim",
      "environment": [
        {
          "name": "DISPLAY",
          "value": ":1"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "make",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "(gdb) nnextractor Launch",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/nnextractor",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "make",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set Disassembly Flavor to Intel",
          "text": "-gdb-set disassembly-flavor intel",
          "ignoreFailures": true
        }
      ]
    }
  ],
  "inputs": [
    {
      "id": "coreDumpPath",
      "type": "promptString",
      "description": "Enter the path to the core dump file",
      "default": "/mnt/wslg/dumps/core."
    }
  ]
}
